# Copy to .env and fill in. Never commit the real .env.

# --- Jira (collectors/) ---
# Base URL of the Jira Cloud site, e.g. https://your-org.atlassian.net
JIRA_BASE_URL=https://hirereidcollins.atlassian.net
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
# Used with your account email for Basic auth (email:token).
JIRA_API_TOKEN=
JIRA_EMAIL=

# --- Anthropic (narrative/) ---
ANTHROPIC_API_KEY=

# --- Slack (drift/notify.py) ---
# Incoming webhook for the program-channel weekly rollup.
SLACK_WEBHOOK_URL=

# --- Runtime ---
# When true, notifications are logged instead of sent (dev/demo). See [8/9].
DRY_RUN=true
# Jira project to scan.
PROJECT_KEY=RC1
# SQLite snapshot store. On Fly.io point this at the mounted volume: /data/drift.db
DB_PATH=data/drift.db
# Shared secret gating POST /drift/run (the scheduler sends it as X-Drift-Token).
# Leave unset for an open local endpoint.
DRIFT_RUN_TOKEN=
